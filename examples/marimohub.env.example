# Copy outside the Nix store, fill in the values, and chmod 0400.
MARIMOHUB_AUTH_OIDC_CLIENT_SECRET=replace-me
MARIMOHUB_AUTH_SESSION_SECRET=replace-with-output-of-openssl-rand-base64-32

# Other backend secrets belong here too, for example:
# MARIMOHUB_STORAGE_S3_ACCESS_KEY_ID=...
# MARIMOHUB_STORAGE_S3_SECRET_ACCESS_KEY=...
# MARIMOHUB_COMPUTE_MODAL_TOKEN_ID=...
# MARIMOHUB_COMPUTE_MODAL_TOKEN_SECRET=...
